@inherits LayoutComponentBase
@inject NavigationManager Nav

<div class="app-shell @(_isDark ? "theme-dark" : "theme-light")">
    <nav class="sidebar">
        <div class="sidebar-header">
            <span class="sidebar-logo">&#128202;</span>
            <span class="sidebar-title">DB Monitor</span>
        </div>
        <ul class="nav-list">
            <li><NavLink href="/" Match="NavLinkMatch.All" class="nav-item"><span class="nav-icon">&#9632;</span> Dashboard</NavLink></li>
            <li><NavLink href="/queries" class="nav-item"><span class="nav-icon">&#9654;</span> Long Queries</NavLink></li>
            <li><NavLink href="/indexes" class="nav-item"><span class="nav-icon">&#128196;</span> Indexes</NavLink></li>
            <li><NavLink href="/errors" class="nav-item"><span class="nav-icon">&#9888;</span> Errors</NavLink></li>
            <li><NavLink href="/audit" class="nav-item"><span class="nav-icon">&#128221;</span> Audit Trail</NavLink></li>
            <li><NavLink href="/logs" class="nav-item"><span class="nav-icon">&#128196;</span> Logs</NavLink></li>
            <li><NavLink href="/settings" class="nav-item"><span class="nav-icon">&#9881;</span> Settings</NavLink></li>
        </ul>
        <div class="sidebar-footer">
            <button class="theme-toggle-btn" @onclick="ToggleTheme" title="Toggle theme">
                @(_isDark ? "☀" : "☽") @(_isDark ? "Light" : "Dark")
            </button>
        </div>
    </nav>
    <main class="main-content">
        <div class="topbar">
            <button class="hamburger" @onclick="ToggleSidebar">&#9776;</button>
            <span class="topbar-title">DB Monitor</span>
        </div>
        @Body
    </main>
</div>

@code {
    private bool _isDark = true;
    private bool _sidebarOpen = false;

    private void ToggleTheme() => _isDark = !_isDark;
    private void ToggleSidebar() => _sidebarOpen = !_sidebarOpen;
}

